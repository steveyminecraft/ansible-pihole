---
extends: default

rules:
  line-length:
    max: 150
    level: warning
  comments:
    min-spaces-from-content: 1
  comments-indentation: disable
  braces:
    max-spaces-inside: 1
  octal-values:
    forbid-implicit-octal: true
    forbid-explicit-octal: true

ignore:
  - /env
  - .ansible
  - .git
  - .github
  - .venv
  - .venv-ci
  - .venv-pr
  - .venv-verify
  - roles/pihole
  - inventory/inventory.yaml
