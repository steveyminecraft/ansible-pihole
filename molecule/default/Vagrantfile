# -*- mode: ruby -*-
# vi: set ft=ruby :

Vagrant.configure("2") do |config|
  # VirtualBox: 192.168.56.0/24 — libvirt (vagrant-56): 192.168.121.0/24 by default here;
  # override ip_libvirt if your KVM network differs. Match inventory file to provider.
  # rockylinux/10 on Vagrant Cloud points at a dated file under pub/rocky/10/ that 404s; the
  # .latest boxes on dl.rockylinux.org are the same images with a working URL (per provider).
  vm_settings = {
    box: "rockylinux/10",
    box_url_virtualbox: "https://dl.rockylinux.org/pub/rocky/10/images/x86_64/Rocky-10-Vagrant-Vbox.latest.x86_64.box",
    box_url_libvirt: "https://dl.rockylinux.org/pub/rocky/10/images/x86_64/Rocky-10-Vagrant-Libvirt.latest.x86_64.box",
    memory: 2048,
    cpus: 4,
    machines: [
      { name: "vagrant-pihole-01", mac: "52:54:00:56:00:04",
        ip_virtualbox: "192.168.56.4", ip_libvirt: "192.168.121.4" },
      { name: "vagrant-pihole-02", mac: "52:54:00:56:00:05",
        ip_virtualbox: "192.168.56.5", ip_libvirt: "192.168.121.5" }
    ]
  }

  ### DEFINE SCRIPT ###
  # Insecure Vagrant public key (matches host ~/.vagrant.d/insecure_private_key); ensures
  # `vagrant` can SSH in when the image omits it (e.g. custom / lab boxes).
  # Source: https://github.com/hashicorp/vagrant/blob/master/keys/vagrant.pub
  $script = <<~'SCRIPT'
    set -e
    VAGRANT_PUB='ssh-rsa  vagrant insecure public key'
    install -d -m 700 -o vagrant -g vagrant /home/vagrant/.ssh
    auth=/home/vagrant/.ssh/authorized_keys
    if ! ( [ -f "$auth" ] && grep -qF "vagrant insecure public key" "$auth" ); then
      echo "$VAGRANT_PUB" >> "$auth"
      chown vagrant:vagrant "$auth"
      chmod 600 "$auth"
    fi
    echo I am provisioning...
    date > /etc/vagrant_provisioned_at
  SCRIPT

  # --- PLUGINS ---------------------------------------------------------------

  if Vagrant.has_plugin?("vagrant-vbguest")
    config.vbguest.auto_update = false
  end

  # --- MACHINES --------------------------------------------------------------

  vm_settings[:machines].each do |machine|
    config.vm.define machine[:name] do |node|
      node.vm.hostname         = machine[:name]
      node.vm.box              = vm_settings[:box]
      node.vm.box_check_update = false

      node.vm.provider "virtualbox" do |v, o|
        o.vm.box_url = vm_settings[:box_url_virtualbox]
        v.memory = vm_settings[:memory]
        v.cpus   = vm_settings[:cpus]
        o.vm.network "private_network",
                     ip: machine[:ip_virtualbox],
                     netmask: "255.255.255.0",
                     auto_config: true
        v.customize ["modifyvm", :id, "--macaddress2", machine[:mac].delete(":")]
        # Linux guest on Linux host: improves timekeeping vs purely emulated timers (TSC noise).
        v.customize ["modifyvm", :id, "--paravirtprovider", "kvm"]
      end

      if Vagrant.has_plugin?("vagrant-libvirt")
        node.vm.provider "libvirt" do |l, o|
          o.vm.box_url = vm_settings[:box_url_libvirt]
          l.memory = vm_settings[:memory]
          l.cpus   = vm_settings[:cpus]
          l.driver = "kvm"
          # Nested/uneven vCPU scheduling can skew TSC; host-passthrough exposes the host CPU
          # (incl. invariant TSC when the host has it) and usually stops unstable-TSC dmesg noise.
          l.cpu_mode = "host-passthrough"
          o.vm.network "private_network",
                       ip: machine[:ip_libvirt],
                       netmask: "255.255.255.0",
                       auto_config: true,
                       libvirt__network_name: "vagrant-56",
                       libvirt__mac: machine[:mac],
                       libvirt__mgmt_network: "none"
        end
      end

      node.vm.provision "shell", inline: $script

      node.trigger.after :destroy do |trigger|
        trigger.info = "Removing known_hosts entry for #{machine[:name]}"
        trigger.on_error = :continue
        trigger.run = { inline: "ssh-keygen -R #{machine[:name]}" }
      end
    end
  end
end
